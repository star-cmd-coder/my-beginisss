        .box {
            transform: translateY(100px);
            height: 270px;
            width: 370px;
            padding: 20px;
            background-color: aqua;
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.50rem;
            background: rgba(0, 255, 255, 0.3);
            backdrop-filter: 10px;
            -webkit-backdrop-filter: 10px;
            box-shadow: 0 4 40px rgba(0, 255, 255, 0.5);
            border: 1px solid rgba(255, 255, 255 0.2);
        }

        body h1 {
            color: white;
            display: flex;
            justify-content: center;
            transform: translateY(50px);
            font-size: 4.1rem;
            font-family: sans-serif;
            color: rgba(255, 255, 255, 1);
        }


        /*Button from here👇*/
        .btn {
            position: absolute;
            top: 135%;
            left: 47.8%;
            transform: scale(2);
            padding: 8px 15px;
            border-radius: 12px; 
            z-index: 0;
            border: none;
            outline: none;
            cursor: pointer;
        }

        .btn::after {
            content: "";
            z-index: -1;
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: #333;
            left: 0;
            top: 0;
            border-radius: 10px;
            position: relative;
        }

        .btn::before {
            content: "";
            background: linear-gradient(45deg,
                    #ff0000, #ff7300, #fffb00, #48ff00,
                    #00ffd5, #002bff, #ff00c8, #ff0000);
            position: absolute;
            top: -2px;
            left: -8px;
            background-size: 600%;
            z-index: -1;
            width: calc(100% + 4px);
            height: calc(100% + 4px);
            filter: blur(2px);

            /*Animation*/
            animation: glowing 20s linear infinite;
            transition: opacity .3s ease-in-out;
            border-radius: 10px;
            opacity: 1;
        }

        @keyframes glowing {
            0% {
                background-position: 0 0;
            }

            50% {
                background-position: 400% 0;
            }

            100% {
                background-position: 0 0;
            }
        }

        .btn:hover::before {
            opacity: 1;
        }

        .btn:active:after {
            background: transparent;
        }

        .btn:active {
            color: #000;
            font-weight: bold;
        }

